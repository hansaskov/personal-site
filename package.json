{
  "name": "astrofy",
  "version": "3.0.0",
  "private": true,
  "description": "Astrofy is a free and open-source template for your Personal Portfolio Website built with Astro and TailwindCSS. Create in minutes a website with Blog, CV, Project Section, Store and RSS Feed.",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "oxlint --fix",
    "format": "oxfmt",
    "check": "oxfmt && oxlint --fix",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.5.3",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "6.3.6",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.1",
    "wrangler": "^4.87.0"
  },
  "devDependencies": {
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
