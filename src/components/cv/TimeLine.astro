---
interface props {
  title: string,
  subtitle: string,
  last?: boolean
}

const { title, subtitle, last = false } = Astro.props;
---

<div class="flex">
  <div>
    <span class="size-4 bg-primary block rounded-full mt-1"></span>
    <span class:list={[
      "bg-primary block w-0.5 translate-x-[7px]",
      {
        "h-[90%]": last === true,
        "h-full": last === false
      }
      ]}></span>
  </div>
  <div class="bd-grid px-5">
    <h3 class="font-semibold mb-1">{title}</h3>
    <span class="font-light text-sm">{subtitle}</span>
    <p class="my-2 text-pretty">
      <slot />
    </p>
  </div>
</div>
