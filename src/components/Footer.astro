---
const today = new Date();
const email = "hans@askov.dk";
const phone = "+45 24 96 51 87";
---

<footer class="footer footer-center py-8 px-4 mt-10">
  <div class="flex items-center gap-3 text-sm text-base-content/50">
    <a
      href={`mailto:${email}`}
      title={email}
      class="flex items-center gap-2 hover:font-semibold hover:text-base-content transition-colors"
    >
      <!-- Mail icon -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <rect width="20" height="16" x="2" y="4" rx="2"></rect>
        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
      </svg>
      {email}
    </a>

    <span class="text-base-content/20 select-none">•</span>

    <span>{today.getFullYear()}</span>

    <span class="text-base-content/20 select-none">•</span>

    <a
      href={`tel:${phone.replace(/\s+/g, "")}`}
      title={phone}
      class="flex items-center gap-2 hover:font-semibold hover:text-base-content transition-colors"
    >
      <!-- Phone icon -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path
          d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
        ></path>
      </svg>
      {phone}
    </a>
  </div>
</footer>
