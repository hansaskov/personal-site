---
import SideBarFooter from "./SideBarFooter.astro";
import { getImage } from "astro:assets";
import SideBarMenu from "./SideBarMenu.astro";
import ProfilePicture from "../media/profile.jpg"
import type { ComponentProps } from "astro/types";

const hero = await getImage({ src: ProfilePicture, format: "webp", width: 384, height: 384 });

interface Props extends ComponentProps<typeof SideBarFooter> {}

const { download_button } = Astro.props;

---

<Fragment slot="head">
  <link rel="preload" as="image" href={hero.src} fetchpriority="high" />
</Fragment>

<div class="drawer-side z-40">
    <label for="my-drawer" class="drawer-overlay"></label>
    <aside
        class="px-2 pt-2 h-auto min-h-full w-76 bg-base-200 text-base-content flex flex-col"
    >
        <div class="w-fit mx-auto mt-5 mb-6">
            <a href="/">
                <div
                    class="avatar transition ease-in-out hover:scale-[102%] block m-auto"
                >
                    <div class="w-32 h-32">
                        <img
                            class="mask mask-circle"
                            width={384}
                            height={384}
                            src={hero.src}
                            alt="Profile image of Hans Askov drinking from a glass looking to the left out of a window."
                            fetchpriority="high"
                        />
                    </div>
                </div>
            </a>
        </div>
        <SideBarMenu />
        <SideBarFooter {download_button} />
    </aside>
</div>


