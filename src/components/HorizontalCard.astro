---
import type { Project } from "../data/projects";
import { Picture } from "astro:assets";

type Props = Project

const { title, desc, img, url, badge, target = "_blank", year } = Astro.props;
---

<div class="rounded-lg bg-base-100 hover:shadow-xl transition ease-in-out hover:scale-[102%]">
  <a href={url} target={target}>
    <div class="hero-content flex-col md:flex-row">
      {img && (
        <Picture
          src={img}
          width={750}
          height={422}
          formats={['avif', 'webp']}
          alt={title}
          class="max-w-full md:max-w-52 rounded-lg"
        />
      )}
      <div class="grow w-full">
        <h1 class="text-xl font-bold">
          {title}
          {badge && <div class="badge badge-secondary mx-2">{badge}</div>}
        </h1> 
        <p class="my-1 text-sm font-light">{year}</p>
        <p class="py-1 text-1xl">{desc}</p>

      </div>
    </div>
  </a>
</div>
