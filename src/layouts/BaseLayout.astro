---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SideBar from "../components/SideBar.astro";
import type { ComponentProps } from "astro/types";
import SpeculationsAPI from "@components/SpeculationsAPI.astro";

interface Props
  extends
    ComponentProps<typeof BaseHead>,
    ComponentProps<typeof Header>,
    ComponentProps<typeof SideBar>,
    ComponentProps<typeof SpeculationsAPI> {
    theme: "light" | "dark";
    class?: string;
}

const props = Astro.props;
---

<!doctype html>
<html lang="en" data-theme={props.theme ?? "light"}>
  <head>
    <BaseHead {...props} />
    <slot name="head" />
  </head>
  <body>
    <div class="bg-base-100 drawer lg:drawer-open">
      <input id="my-drawer" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content bg-base-100">
        <Header {...props} />
        <div class="md:flex md:justify-center">
          <main
            class:list={[
              "p-6 px-12 pt-10 lg:max-w-[900px] max-w-[100vw]",
              Astro.props.class,
            ]}
          >
            <slot />
          </main>
        </div>
        <Footer />
      </div>
      {props.includeSidebar && <SideBar {...props} />}
    </div>
  </body>
</html>

<SpeculationsAPI {...props} />
