---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { projects } from "../data/projects";
const prefetchUrls =["/", "/cv", "/projects"]
const includeSidebar = true
---

<BaseLayout title="Projects" description="List of all the projects i have worked on" {prefetchUrls} {includeSidebar}  >
    <div>
        <div class="text-3xl w-full font-bold mb-5">My projects</div>
    </div>

    {
        projects.map((project, i) => (
            <>
                {i > 0 && <div class="divider my-0" />}
                <HorizontalCard {...project} />
            </>
        ))
    }
</BaseLayout>
