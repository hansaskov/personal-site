---
import BaseLayout from "@layouts/BaseLayout.astro";
import HorizontalCard from "@components/HorizontalCard.astro";
import { projects } from "@lib/data/projects";

const prefetchUrls = ["/", "/cv"];
const includeSidebar = true;
---

<BaseLayout
    class="space-y-8"
    title="Projects"
    description="List of all projects Hans Askov has worked on"
    theme="light"
    {prefetchUrls}
    {includeSidebar}
>
    <h1 class="text-2xl lg:text-5xl font-semibold text-base-content/85">My projects</h1>
    {
        projects.map((project, i) => (
            <>
                {i > 0 && <hr class="border-base-300" />}
                <HorizontalCard {...project} />
            </>
        ))
    }
</BaseLayout>
