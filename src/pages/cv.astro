---
import BaseLayout from "../layouts/BaseLayout.astro";
import NameIntro from "../components/NameIntro.astro";
import TimeLine from "../components/TimeLine.astro";
import { experiances } from "@data/experiances";
import TimeLineHeader from "@components/TimeLineHeader.astro";
import TimeLineBody from "@components/TimeLineBody.astro";

const download_button_url = "/hans-askov-cv.pdf";
const prefetchUrls = ["/", "/projects"];
const includeSidebar = true;
---

<BaseLayout
  class="prose prose-sm md:prose-base space-y-8"
  title="CV"
  description="Hans askov's CV"
  theme="light"
  {prefetchUrls}
  {includeSidebar}
  download_button={{ title: "Download CV", url: download_button_url }}
>
  <NameIntro />

  <p>
    I'm Hans, a software engineer who specialize in fullstack web development
    and building systems that hold up under real load. I have built a production
    analytics platform ingesting 420M+ inspections a year, cutting dashboard
    load times by 100× and storage costs by 92%. Now looking to bring that
    performance and cost discipline to a backend or fullstack role.
  </p>

  <div class="space-y-4">
    <h2 class="font-bold">Experience</h2>
    <div class="space-y-8 not-prose">
      {
        experiances.map((experiance) => (
          <div class="space-y-4">
            <TimeLineHeader {...experiance} />
            {experiance.roles.map((role) => (
              <div class="flex gap-4 not-prose pl-6">
                <div>
                  <span class="size-4 bg-primary block rounded-full mt-1" />
                  <span class="bg-primary h-full block w-0.5 translate-x-[7px]" />
                </div>
                <div>
                  <TimeLineBody {...role} />
                </div>
              </div>
            ))}
          </div>
        ))
      }
    </div>

    <div class="space-y-4">
      <h2 class="w-full font-bold">Education</h2>
      <div class="time-line-container grid gap-4">
        <TimeLine>
          <h3 class="font-semibold mb-1">
            MSc in Software Engineering, Odense - Southern University of Denmark
          </h3>
          <span class="font-light text-sm">2023 - 2025 • 2 years</span>
          <div class="my-2 text-pretty">
            Specialization in distributed systems and backend engineering, with
            electives in cybersecurity, data security and biometric security.
          </div>
        </TimeLine>
        <TimeLine last={true}>
          <h3 class="font-semibold mb-1">
            BEng in Robotic Systems, Odense - Southern University of Denmark
          </h3>
          <span class="font-light text-sm"
            >2019 - 2023 • 3 years and 5 months</span
          >
          <div class="my-2 text-pretty">
            Robotics introduced my love for software and mathematics, this
            includes control theory, computer vision, and ML. A key project was
            to program a UR5 robot arm to detect, grasp and throw objects using
            collision-aware motion planning.
          </div>
        </TimeLine>
      </div>
    </div>
  </div>
</BaseLayout>
