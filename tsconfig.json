{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "strictNullChecks": true,
    "paths": {
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@media/*": ["./src/media/*"],
      "@data/*": ["./src/data/*"],
      "@lib/*": ["./src/*"]
    }
  }
}
